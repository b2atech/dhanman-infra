global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "node"
    static_configs:
      - targets:
          - "{{ ansible_default_ipv4.address }}:9100"
        labels:
          env: "{{ env }}"
          host: "{{ inventory_hostname }}"

  - job_name: "dhanman_services"
    static_configs:
      - targets:
{% for svc in services %}
          - "127.0.0.1:{{ svc.port }}"
{% endfor %}
        labels:
          env: "{{ env }}"

  - job_name: "postgres"
    static_configs:
      - targets:
          - "127.0.0.1:9187"
        labels:
          env: "{{ env }}"
