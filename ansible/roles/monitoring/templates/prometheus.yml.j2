global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    env: "{{ env }}"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["127.0.0.1:9093"]

rule_files:
  - "/etc/prometheus/rules/*.yml"

scrape_configs:

  - job_name: node
    static_configs:
      - targets: ["127.0.0.1:9100"]
        labels:
          env: "{{ env }}"
          host: "{{ inventory_hostname }}"

  - job_name: dhanman_services
    metrics_path: /metrics
    static_configs:
{% for svc in services if svc.has_metrics | default(true) %}
      - targets: ["127.0.0.1:{{ svc.port }}"]
        labels:
          env: "{{ env }}"
          service: "{{ svc.name }}"
{% endfor %}

  - job_name: postgres
    static_configs:
      - targets: ["127.0.0.1:9187"]
        labels:
          env: "{{ env }}"

  - job_name: rabbitmq
    static_configs:
      - targets: ["127.0.0.1:15692"]
        labels:
          env: "{{ env }}"

  - job_name: nginx
    static_configs:
      - targets: ["127.0.0.1:9113"]
        labels:
          env: "{{ env }}"

  - job_name: redis
    static_configs:
      - targets: ["127.0.0.1:9121"]
        labels:
          env: "{{ env }}"

  - job_name: minio
    metrics_path: /minio/v2/metrics/cluster
    static_configs:
      - targets: ["127.0.0.1:9000"]
        labels:
          env: "{{ env }}"
    bearer_token: "{{ minio_metrics_token | default('') }}"

  - job_name: blackbox_http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for svc in services %}
          - "https://{{ svc.domain }}/health"
{% endfor %}
        labels:
          env: "{{ env }}"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "127.0.0.1:9115"

  - job_name: blackbox_ssl
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
      - targets:
{% for svc in services %}
          - "{{ svc.domain }}:443"
{% endfor %}
        labels:
          env: "{{ env }}"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "127.0.0.1:9115"

  - job_name: vault
    metrics_path: /v1/sys/metrics
    params:
      format: [prometheus]
    static_configs:
      - targets: ["127.0.0.1:8200"]
        labels:
          env: "{{ env }}"
