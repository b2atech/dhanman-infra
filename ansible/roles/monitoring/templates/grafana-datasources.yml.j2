apiVersion: 1

deleteDatasources:
  - name: prometheus
    orgId: 1
  - name: loki
    orgId: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://127.0.0.1:9090
    isDefault: true
    uid: prometheus
    jsonData:
      timeInterval: "15s"
      httpMethod: POST
    editable: false

  - name: Loki
    type: loki
    access: proxy
    url: http://127.0.0.1:3100
    uid: loki
    jsonData:
      maxLines: 1000
    editable: false
