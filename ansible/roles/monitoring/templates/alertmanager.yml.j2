global:
  smtp_smarthost: "smtp-relay.brevo.com:587"
  smtp_from: "alerts@dhanman.com"
  smtp_auth_username: "{{ smtp_username | default('8ba6c9001@smtp-brevo.com') }}"
  smtp_auth_password: "{{ smtp_password | default('') }}"
  smtp_require_tls: true
  resolve_timeout: 5m

route:
  receiver: default
  group_by: ["alertname", "env", "service"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - matchers:
        - severity="critical"
      receiver: critical
      repeat_interval: 1h
    - matchers:
        - severity="high"
      receiver: high
      repeat_interval: 2h

receivers:
  - name: default
    email_configs:
      - to: "{{ alert_emails | default('devops@dhanman.com') }}"
        send_resolved: true
        headers:
          Subject: '[{{ "{{" }} .Status | toUpper {{ "}}" }}] {{ "{{" }} .GroupLabels.alertname {{ "}}" }} ({{ "{{" }} .GroupLabels.env {{ "}}" }})'

  - name: high
    email_configs:
      - to: "{{ alert_emails | default('devops@dhanman.com') }}"
        send_resolved: true
        headers:
          Subject: '⚠️ [{{ "{{" }} .Status | toUpper {{ "}}" }}] {{ "{{" }} .GroupLabels.alertname {{ "}}" }} ({{ "{{" }} .GroupLabels.env {{ "}}" }})'

  - name: critical
    email_configs:
      - to: "{{ alert_emails | default('devops@dhanman.com') }}"
        send_resolved: true
        headers:
          Subject: '🔴 CRITICAL [{{ "{{" }} .Status | toUpper {{ "}}" }}] {{ "{{" }} .GroupLabels.alertname {{ "}}" }} ({{ "{{" }} .GroupLabels.env {{ "}}" }})'

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal: ["env", "alertname"]
