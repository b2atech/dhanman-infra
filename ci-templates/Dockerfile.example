# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy csproj and restore dependencies
COPY ["src/Dhanman.SERVICE_NAME.Api/Dhanman.SERVICE_NAME.Api.csproj", "src/Dhanman.SERVICE_NAME.Api/"]
# If you have shared projects, copy them too:
# COPY ["src/Dhanman.Common/Dhanman.Common.csproj", "src/Dhanman.Common/"]

RUN dotnet restore "src/Dhanman.SERVICE_NAME.Api/Dhanman.SERVICE_NAME.Api.csproj"

# Copy everything else and build
COPY . .
WORKDIR "/src/src/Dhanman.SERVICE_NAME.Api"
RUN dotnet build "Dhanman.SERVICE_NAME.Api.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "Dhanman.SERVICE_NAME.Api.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

# Create non-root user
RUN groupadd -r dhanman && useradd -r -g dhanman dhanman

# Copy published app
COPY --from=publish /app/publish .

# Create logs directory
RUN mkdir -p /logs && chown -R dhanman:dhanman /logs

# Switch to non-root user
USER dhanman

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://localhost/health || exit 1

# Set entry point
ENTRYPOINT ["dotnet", "Dhanman.SERVICE_NAME.Api.dll"]
