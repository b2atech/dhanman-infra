# Nginx configuration for Dhanman UI (no websocket) - {{ item.name }}
# Static frontend hosted at {{ item.path }}

server {
    listen 80;
    listen [::]:80;
    server_name {{ item.domain }};

    # Redirect HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ item.domain }};

    # SSL certificate paths (to be configured with certbot)
    ssl_certificate {{ tls_cert_path }}/{{ item.domain }}/fullchain.pem;
    ssl_certificate_key {{ tls_cert_path }}/{{ item.domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Document root for static files
    root {{ item.path }};
    index index.html;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Static file handling
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Logging
    access_log /var/log/nginx/{{ item.domain }}.access.log;
    error_log /var/log/nginx/{{ item.domain }}.error.log;
}
